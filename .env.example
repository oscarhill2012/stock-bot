# Copy to .env and fill in real values. Never commit .env.

# === Stock data providers ===
FINNHUB_API_KEY=your_finnhub_key_here
TIINGO_API_KEY=                       # Tiingo News (free tier: 1000 articles/day/ticker)
QUIVER_QUANT_API_KEY=your_quiver_quant_key_here
EDGAR_IDENTITY=Your Name your@email.com
FINRA_CLIENT_ID=your_finra_client_id_here         # FINRA Developer API — OAuth2 client credentials
FINRA_CLIENT_SECRET=your_finra_client_secret_here # Register at https://developer.finra.org/

# === Brokerage (Trading 212) ===
TRADING212_API_KEY=your_trading212_paper_key_here
TRADING212_MODE=paper
TRADING212_BASE_URL=https://demo.trading212.com

# === Google ADK ===
# Either a direct API key OR Vertex credentials, not both.
# GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# === StockBot runtime ===
STOCKBOT_ENV=dev
DATABASE_URL=
SCHEDULER_JOB=stockbot-tick
LOG_LEVEL=INFO
