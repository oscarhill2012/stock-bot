# Data caches (raw market data shouldn't be committed)
data/cache/
data/raw/

# LLM report cache — hash-memoised verdicts written by the News + Fundamental
# analysts. Never commit; each developer's cache is an isolated local artefact.
cache/
# Exception: the backtest cache *source package* must be tracked.
!src/backtest/cache/

# Local dev SQLite — persistence tests write into it on every run; should
# not be tracked. Schema is owned by SQLAlchemy ORM in orchestrator/persistence.py.
data/stockbot.db
data/stockbot.db-journal
data/stockbot.db-wal
data/stockbot.db-shm

# Surface trace outputs — written by scripts/trace_tick.py; never commit.
docs/surface-traces/

# Local-only worktrees for parallel feature work.
.worktrees/

# Backtest golden-cache SQLite files — binary, large, developer-local only.
backtests/
